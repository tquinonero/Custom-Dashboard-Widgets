ng -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#cccccc\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#cccccc\">123 Business Ave<br/>New York, NY 10001</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n</div>\n<!-- /wp:columns -->\n<!-- wp:separator { \"align\":\"full\", \"color\":\"#333333\" } -->\n<hr class=\"wp-block-separator has-text-color has-background has-background-color has-text-color has-background\"/>\n<!-- /wp:separator -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#888888\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#888888\">© 2026 Company Name. All rights reserved.</p>\n<!-- /wp:paragraph -->\n</footer>\n<!-- /wp:group -->"
