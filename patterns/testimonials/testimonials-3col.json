  "content": "<!-- wp:columns { \"align\":\"full\", \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"96px\", \"bottom\":\"96px\"} }, \"color\":{ \"background\":\"#f8f6f3\"} } } -->\n<div class=\"wp-block-columns alignfull has-background\" style=\"background-color:#f8f6f3;padding-top:96px;padding-bottom:96px\">\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"32px\", \"right\":\"32px\", \"bottom\":\"32px\", \"left\":\"32px\"} }, \"backgroundColor\":\"white\" } } -->\n<div class=\"wp-block-column has-white-background-color has-background\" style=\"background-color:white;padding-top:32px;padding-right:32px;padding-bottom:32px;padding-left:32px\">\n<!-- wp:paragraph { \"textColor\":\"#c9a962\", \"fontSize\":\"large\" } -->\n<p class=\"has-text-color has-large-font-size\" style=\"color:#c9a962\">\"</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"textColor\":\"#444444\" } -->\n<p class=\"has-text-color\" style=\"color:#444444\">Working with this team was an absolute pleasure. They delivered exceptional results on time and within budget.</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"fontSize\":\"small\", \"textColor\":\"#666666\" } -->\n<p class=\"has-text-color has-small-font-size\" style=\"color:#666666\">— John Smith, CEO</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"32px\", \"right\":\"32px\", \"bottom\":\"32px\", \"left\":\"32px\"} }, \"backgroundColor\":\"white\" } } -->\n<div class=\"wp-block-column has-white-background-color has-background\" style=\"background-color:white;padding-top:32px;padding-right:32px;padding-bottom:32px;padding-left:32px\">\n<!-- wp:paragraph { \"textColor\":\"#c9a962\", \"fontSize\":\"large\" } -->\n<p class=\"has-text-color has-large-font-size\" style=\"color:#c9a962\">\"</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"textColor\":\"#444444\" } -->\n<p class=\"has-text-color\" style=\"color:#444444\">Their expertise and professionalism exceeded all expectations. Highly recommend to anyone seeking quality.</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"fontSize\":\"small\", \"textColor\":\"#666666\" } -->\n<p class=\"has-text-color has-small-font-size\" style=\"color:#666666\">— Sarah Johnson, Director</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"32px\", \"right\":\"32px\", \"bottom\":\"32px\", \"left\":\"32px\"} }, \"backgroundColor\":\"white\" } } -->\n<div class=\"wp-block-column has-white-background-color has-background\" style=\"background-color:white;padding-top:32px;padding-right:32px;padding-bottom:32px;padding-left:32px\">\n<!-- wp:paragraph { \"textColor\":\"#c9a962\", \"fontSize\":\"large\" } -->\n<p class=\"has-text-color has-large-font-size\" style=\"color:#c9a962\">\"</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"textColor\":\"#444444\" } -->\n<p class=\"has-text-color\" style=\"color:#444444\">Incredible attention to detail and outstanding customer service. We couldn't be happier with the outcome.</p>\n<!-- /wp:paragraph -->\n<!-- wp:paragraph { \"fontSize\":\"small\", \"textColor\":\"#666666\" } -->\n<p class=\"has-text-color has-small-font-size\" style=\"color:#666666\">— Michael Brown, Founder</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n</div>\n<!-- /wp:columns -->"
}
