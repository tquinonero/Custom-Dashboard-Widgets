  "content": "<!-- wp:columns { \"align\":\"full\", \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"96px\", \"bottom\":\"96px\"} }, \"color\":{ \"background\":\"#ffffff\"} } } -->\n<div class=\"wp-block-columns alignfull has-background\" style=\"background-color:#ffffff;padding-top:96px;padding-bottom:96px\">\n<!-- wp:column {} -->\n<div class=\"wp-block-column\">\n<!-- wp:image { \"align\":\"center\", \"width\":150, \"height\":150, \"sizeSlug\":\"thumbnail\", \"className\":\"is-style-rounded\" } -->\n<div class=\"wp-block-image is-style-rounded\"><figure class=\"aligncenter size-thumbnail is-resized is-style-rounded\"><img alt=\"Team Member\" src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300\" width=\"150\" height=\"150\"/></figure></div>\n<!-- /wp:image -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">John Doe</h3>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#c9a962\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#c9a962\">CEO</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n<!-- wp:column {} -->\n<div class=\"wp-block-column\">\n<!-- wp:image { \"align\":\"center\", \"width\":150, \"height\":150, \"sizeSlug\":\"thumbnail\", \"className\":\"is-style-rounded\" } -->\n<div class=\"wp-block-image is-style-rounded\"><figure class=\"aligncenter size-thumbnail is-resized is-style-rounded\"><img alt=\"Team Member\" src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=300\" width=\"150\" height=\"150\"/></figure></div>\n<!-- /wp:image -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">Jane Smith</h3>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#c9a962\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#c9a962\">Creative Director</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n<!-- wp:column {} -->\n<div class=\"wp-block-column\">\n<!-- wp:image { \"align\":\"center\", \"width\":150, \"height\":150, \"sizeSlug\":\"thumbnail\", \"className\":\"is-style-rounded\" } -->\n<div class=\"wp-block-image is-style-rounded\"><figure class=\"aligncenter size-thumbnail is-resized is-style-rounded\"><img alt=\"Team Member\" src=\"https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=300\" width=\"150\" height=\"150\"/></figure></div>\n<!-- /wp:image -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">Mike Johnson</h3>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#c9a962\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#c9a962\">Lead Developer</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n<!-- wp:column {} -->\n<div class=\"wp-block-column\">\n<!-- wp:image { \"align\":\"center\", \"width\":150, \"height\":150, \"sizeSlug\":\"thumbnail\", \"className\":\"is-style-rounded\" } -->\n<div class=\"wp-block-image is-style-rounded\"><figure class=\"aligncenter size-thumbnail is-resized is-style-rounded\"><img alt=\"Team Member\" src=\"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=300\" width=\"150\" height=\"150\"/></figure></div>\n<!-- /wp:image -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">Sarah Williams</h3>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#c9a962\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#c9a962\">Marketing Head</p>\n<!-- /wp:paragraph -->\n</div>\n<!-- /wp:column -->\n</div>\n<!-- /wp:columns -->"
