  "content": "<!-- wp:columns { \"align\":\"full\", \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"96px\", \"bottom\":\"96px\"} }, \"color\":{ \"background\":\"#f8f6f3\"} } } -->\n<div class=\"wp-block-columns alignfull has-background\" style=\"background-color:#f8f6f3;padding-top:96px;padding-bottom:96px\">\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"48px\", \"right\":\"40px\", \"bottom\":\"48px\", \"left\":\"40px\"} }, \"backgroundColor\":\"white\" } } -->\n<div class=\"wp-block-column has-white-background-color has-background\" style=\"background-color:white;padding-top:48px;padding-right:40px;padding-bottom:48px;padding-left:40px\">\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">Basic</h3>\n<!-- /wp:heading -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":2, \"textColor\":\"#1a1a1a\" } -->\n<h2 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">$29<span style=\"font-size:16px\">/mo</span></h2>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#666666\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#666666\">Perfect for individuals</p>\n<!-- /wp:paragraph -->\n<!-- wp:separator {} -->\n<hr class=\"wp-block-separator\"/>\n<!-- /wp:separator -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#444444\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#444444\">Feature 1<br/>Feature 2<br/>Basic Support</p>\n<!-- /wp:paragraph -->\n<!-- wp:buttons { \"layout\":{ \"type\":\"flex\", \"justifyContent\":\"center\"} } -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button { \"backgroundColor\":\"#1a1a1a\", \"textColor\":\"white\" } -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link has-white-color has-background\" href=\"#\" style=\"background-color:#1a1a1a;color:#ffffff\">Get Started</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:column -->\n\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"48px\", \"right\":\"40px\", \"bottom\":\"48px\", \"left\":\"40px\"} }, \"backgroundColor\":\"#1a1a1a\" }, \"textColor\":\"white\" } -->\n<div class=\"wp-block-column has-white-color has-background\" style=\"background-color:#1a1a1a;padding-top:48px;padding-right:40px;padding-bottom:48px;padding-left:40px;color:white\">\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#c9a962\", \"fontSize\":\"small\" } -->\n<p class=\"has-text-align-center has-text-color has-small-font-size\" style=\"color:#c9a962\">MOST POPULAR</p>\n<!-- /wp:paragraph -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"white\" } -->\n<h3 class=\"has-text-align-center has-white-color has-text-color\">Pro</h3>\n<!-- /wp:heading -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":2, \"textColor\":\"white\" } -->\n<h2 class=\"has-text-align-center has-white-color has-text-color\">$79<span style=\"font-size:16px\">/mo</span></h2>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#cccccc\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#cccccc\">Perfect for small teams</p>\n<!-- /wp:paragraph -->\n<!-- wp:separator { \"color\":\"#333333\" } -->\n<hr class=\"wp-block-separator has-text-color has-background has-background-color has-text-color has-background\"/>\n<!-- /wp:separator -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"white\" } -->\n<p class=\"has-text-align-center has-white-color has-text-color\">All Basic features<br/>Priority Support<br/>Advanced Analytics</p>\n<!-- /wp:paragraph -->\n<!-- wp:buttons { \"layout\":{ \"type\":\"flex\", \"justifyContent\":\"center\"} } -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button { \"backgroundColor\":\"#c9a962\", \"textColor\":\"#1a1a1a\" } -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link has-text-color has-background\" href=\"#\" style=\"background-color:#c9a962;color:#1a1a1a\">Get Started</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:column -->\n\n<!-- wp:column { \"style\":{ \"spacing\":{ \"padding\":{ \"top\":\"48px\", \"right\":\"40px\", \"bottom\":\"48px\", \"left\":\"40px\"} }, \"backgroundColor\":\"white\" } } -->\n<div class=\"wp-block-column has-white-background-color has-background\" style=\"background-color:white;padding-top:48px;padding-right:40px;padding-bottom:48px;padding-left:40px\">\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":3, \"textColor\":\"#1a1a1a\" } -->\n<h3 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">Enterprise</h3>\n<!-- /wp:heading -->\n<!-- wp:heading { \"textAlign\":\"center\", \"level\":2, \"textColor\":\"#1a1a1a\" } -->\n<h2 class=\"has-text-align-center has-text-color\" style=\"color:#1a1a1a\">$199<span style=\"font-size:16px\">/mo</span></h2>\n<!-- /wp:heading -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#666666\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#666666\">For large organizations</p>\n<!-- /wp:paragraph -->\n<!-- wp:separator {} -->\n<hr class=\"wp-block-separator\"/>\n<!-- /wp:separator -->\n<!-- wp:paragraph { \"align\":\"center\", \"textColor\":\"#444444\" } -->\n<p class=\"has-text-align-center has-text-color\" style=\"color:#444444\">All Pro features<br/>24/7 Dedicated Support<br/>Custom Integrations</p>\n<!-- /wp:paragraph -->\n<!-- wp:buttons { \"layout\":{ \"type\":\"flex\", \"justifyContent\":\"center\"} } -->\n<div class=\"wp-block-buttons\">\n<!-- wp:button { \"backgroundColor\":\"#1a1a1a\", \"textColor\":\"white\" } -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link has-white-color has-background\" href=\"#\" style=\"background-color:#1a1a1a;color:#ffffff\">Contact Us</a></div>\n<!-- /wp:button -->\n</div>\n<!-- /wp:buttons -->\n</div>\n<!-- /wp:column -->\n</div>\n<!-- /wp:columns -->"
}
