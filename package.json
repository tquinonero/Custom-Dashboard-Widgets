{
  "name": "cdw-custom-dashboard-widgets",
  "version": "3.0.0",
  "description": "Custom Dashboard Widgets - Modernized with React and REST API",
  "author": "Toni Quiñonero",
  "license": "GPL-3.0",
  "scripts": {
    "start": "wp-scripts start",
    "build": "wp-scripts build",
    "dev": "wp-scripts start",
    "test:js": "jest",
    "test:php": "vendor/bin/phpunit",
    "test:integration": "vendor/bin/phpunit --config phpunit-integration.xml"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.16.0",
    "@wordpress/components": "^28.8.0",
    "@wordpress/data": "^10.16.0",
    "@wordpress/element": "^6.16.0",
    "@wordpress/i18n": "^5.16.0",
    "chart.js": "^4.4.1",
    "react-chartjs-2": "^5.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@wordpress/jest-preset-default": "^12.40.0",
    "@wordpress/scripts": "^30.5.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "preset": "@wordpress/jest-preset-default",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "@testing-library/jest-dom"
    ],
    "moduleNameMapper": {
      "\\.(css|scss)$": "<rootDir>/tests/js/__mocks__/styleMock.js"
    }
  }
}
