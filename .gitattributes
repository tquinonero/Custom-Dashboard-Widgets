# export-ignore tells `git archive --worktree-attributes` to omit these
# paths from the distribution zip.  Mirror of .distignore.

# Development tools & config
.github/               export-ignore
.ddev/                 export-ignore
.gitattributes         export-ignore
.gitignore             export-ignore
.distignore            export-ignore
.editorconfig          export-ignore
babel.config.js        export-ignore
phpunit.xml            export-ignore
phpunit-integration.xml export-ignore
phpcs.xml              export-ignore
phpstan.neon           export-ignore
phpstan-bootstrap.php  export-ignore
patchwork.json         export-ignore
prompt.txt             export-ignore
known_issues.json      export-ignore
wp-tests-config.php    export-ignore
wp-tests-config-sample.php export-ignore

# Source (compiled into build/)
src/                   export-ignore

# Tests
tests/                 export-ignore

# Dependency source (ship only what plugin needs at runtime)
vendor/                export-ignore
node_modules/          export-ignore

# Composer & npm metadata
composer.json          export-ignore
composer.lock          export-ignore
package.json           export-ignore
package-lock.json      export-ignore
